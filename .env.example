# Environment variables read by the Vite build at compile time.
# Copy this file to .env.local and fill in real values for local development,
# or set them in the Vercel project dashboard for hosted builds.

# --- Supabase ----------------------------------------------------------------
# Project URL + anon key. Used by src/supabase.js to create the client.
# The hardcoded fallbacks in src/supabase.js point at the production project,
# so leaving these unset is fine for local development if you're OK hitting
# production data. Set them explicitly to point at a preview/staging project.
VITE_SUPABASE_URL=https://mxcefgbaaylddnyxrnao.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# --- API base URL ------------------------------------------------------------
# Absolute origin where the Vercel /api/* serverless functions live.
#
# - Web build (Vercel): LEAVE BLANK. Empty string means every fetch
#   collapses to a relative `/api/...` and the browser resolves it against
#   the current origin (where the SPA was served from). This is how the
#   web build talks to its own /api/* endpoints today.
#
# - iOS / Capacitor build: SET TO https://cygne.skin. The WKWebView loads
#   from capacitor://localhost so relative paths would fail; the absolute
#   URL routes /api/* calls back to the same Vercel deployment that hosts
#   the web app.
#
VITE_API_BASE_URL=
